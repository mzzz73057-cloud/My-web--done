{
  "name": "pfe-english-fluency-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend for gamified English fluency learning platform (Node.js + Express + MongoDB)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx kill-port 4000 && nodemon server.js",
    "dev:clean": "npx kill-port 4000 4001 4002 4003 4004 && nodemon server.js",
    "dev:alt": "PORT=4001 nodemon server.js",
    "dev:alt2": "PORT=4002 nodemon server.js",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "openai": "^4.1.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.29.5",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "kill-port": "^2.0.1",
    "nodemon": "^3.0.1"
  }
}
